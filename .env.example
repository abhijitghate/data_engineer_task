# PostgreSQL bootstrap credentials (used by postgres container only).
POSTGRES_DB=scope_ratings
POSTGRES_USER=scope_admin
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Per-service runtime DB URLs.
# Use least-privilege DB roles where possible:
# - MIGRATION_DATABASE_URL: admin role (DDL/migrations)
# - API_DATABASE_URL: read-only app role
# - PIPELINE_DATABASE_URL: write role for ingestion
# - TEST_DATABASE_URL: isolated test role (or same as pipeline for local dev)
MIGRATION_DATABASE_URL=postgresql://scope_admin:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/scope_ratings
API_DATABASE_URL=postgresql://scope_app_read:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/scope_ratings
PIPELINE_DATABASE_URL=postgresql://scope_pipeline_write:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/scope_ratings
TEST_DATABASE_URL=postgresql://scope_pipeline_write:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/scope_ratings

# Optional: if set, Alembic migration 20260608_04 will create/update LOGIN roles.
# If omitted, migration still applies grants to permission roles and existing users.
API_DB_USER=scope_app_read
API_DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
PIPELINE_DB_USER=scope_pipeline_write
PIPELINE_DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
